{"seq": 5, "tick": 5, "step": 5, "braille": "⢜", "curr8": "9C", "curr6": "1C", "d1_8": "6B", "d2_8": "A1", "d1_6": "2B", "d2_6": "21", "rel16": "0", "header8": "1C", "pattern16": "1C21", "hexagram_index": 28, "hexagram_order": 29, "hexagram": "䷜", "hexagram_codepoint": "U+4DDC", "projection_window": "curr6", "projection_bits": 6, "quadrant": "xx", "phase": "p1", "lane": "04", "leaf": "0004", "path": "artifact://prelude/xx/p1/04/0004", "legacy_projection": {"seq": 5, "timestamp": "1970-01-01T00:00:06Z", "event": "universe.canon.event", "payload": {"canon_id": "prelude", "canon_file": "canon-prelude.ndjson", "canon_seq": 3, "canon_event": "paragraph", "canon_line_sha256": "sha256:c67f532c8ba9d5f45e768673a08d31f1c11ced964184edc1b56bc7a54d37ced6", "record": {"event": "paragraph", "id": "prologue", "text": "In the beginning, we worshiped ideals, and they shaped our character. Truth was not owned, it was pursued. Goodness was not calculated, it was practiced.", "matrix": [0, 0, 0, 0, 0, 0, 0], "angle": 0, "t": 1739691001100}}}, "transcript": "䷜ | ⢜ | 1C/1C21 | artifact://prelude/xx/p1/04/0004"}
