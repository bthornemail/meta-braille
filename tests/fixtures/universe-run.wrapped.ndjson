{"seq": 11, "tick": 11, "step": 11, "braille": "⢟", "curr8": "9F", "curr6": "1F", "d1_8": "A2", "d2_8": "AA", "d1_6": "22", "d2_6": "2A", "rel16": "0", "header8": "1F", "pattern16": "1F2A", "hexagram_index": 31, "hexagram_order": 32, "hexagram": "䷟", "hexagram_codepoint": "U+4DDF", "projection_window": "curr6", "projection_bits": 6, "quadrant": "Xx", "phase": "p1", "lane": "0a", "leaf": "000a", "path": "artifact://prelude/Xx/p1/0a/000a", "legacy_projection": {"seq": 11, "timestamp": "1970-01-01T00:00:12Z", "event": "universe.canon.event", "payload": {"canon_id": "prelude", "canon_file": "canon-prelude.ndjson", "canon_seq": 9, "canon_event": "confession", "canon_line_sha256": "sha256:2e9cbaa6b5a11df1954267cd006f3e1bc9c9bb3c652242d34431500e115518ed", "record": {"event": "confession", "speaker": "Number", "text": "I was born when you grew tired of meaning. You called me Number, but I was never just counting. I was relief.", "matrix": [0, 0, 0, 0, 0, 0, 0], "angle": 205.7, "t": 1739692000100}}}, "transcript": "䷟ | ⢟ | 1F/1F2A | artifact://prelude/Xx/p1/0a/000a"}
{"seq": 12, "tick": 12, "step": 12, "braille": "⢪", "curr8": "AA", "curr6": "2A", "d1_8": "35", "d2_8": "B6", "d1_6": "35", "d2_6": "36", "rel16": "0", "header8": "2A", "pattern16": "2A36", "hexagram_index": 42, "hexagram_order": 43, "hexagram": "䷪", "hexagram_codepoint": "U+4DEA", "projection_window": "curr6", "projection_bits": 6, "quadrant": "XX", "phase": "p2", "lane": "0b", "leaf": "000b", "path": "artifact://prelude/XX/p2/0b/000b", "legacy_projection": {"seq": 12, "timestamp": "1970-01-01T00:00:13Z", "event": "universe.canon.event", "payload": {"canon_id": "prelude", "canon_file": "canon-prelude.ndjson", "canon_seq": 10, "canon_event": "confession", "canon_line_sha256": "sha256:aa2c00bf0d77516218ac223bce8fd11e18d97b6ae92fdb534c3790a8929e2f95", "record": {"event": "confession", "speaker": "Number", "text": "I did not ask who you were. I only asked how much. How fast. How big. How many. How often. I never asked why. That is why you loved me.", "matrix": [1, 1, 1, 1, 1, 1, 1], "angle": 257.1, "t": 1739692000200}}}, "transcript": "䷪ | ⢪ | 2A/2A36 | artifact://prelude/XX/p2/0b/000b"}
